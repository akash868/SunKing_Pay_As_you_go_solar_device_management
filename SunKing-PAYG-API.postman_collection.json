{
  "info": {
    "_postman_id": "sunking-payg-2024",
    "name": "Sun King PAYG Solar Backend",
    "description": "Complete API collection for Sun King Pay-As-You-Go Solar System Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Login as Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success) {",
                  "  pm.collectionVariables.set('token', jsonData.data.accessToken);",
                  "  pm.test('Login successful', () => pm.response.to.have.status(200));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        },
        {
          "name": "Login as Agent",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"agent\",\n  \"password\": \"Admin@123\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/auth/login"
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Kamau\",\n  \"phoneNumber\": \"+254712345678\",\n  \"email\": \"john.kamau@example.com\",\n  \"nationalId\": \"KE12345678\",\n  \"region\": \"Nairobi\",\n  \"address\": \"123 Moi Avenue, Nairobi\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/customers"
          }
        },
        {
          "name": "Get Customer by ID",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{baseUrl}}/api/v1/customers/{{customerId}}"
          }
        },
        {
          "name": "List Customers (Paginated)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/v1/customers?page=0&size=20",
              "query": [
                {"key": "page", "value": "0"},
                {"key": "size", "value": "20"},
                {"key": "search", "value": "", "disabled": true}
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Devices",
      "item": [
        {
          "name": "Register Device",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"serialNumber\": \"SK-PRO-200-999\",\n  \"model\": \"SunKing Pro 200\",\n  \"description\": \"200W solar home system with 4 LED bulbs\",\n  \"totalCost\": 15000.00,\n  \"dailyRate\": 100.00,\n  \"gracePeriodDays\": 3\n}"
            },
            "url": "{{baseUrl}}/api/v1/devices"
          }
        },
        {
          "name": "Assign Device to Customer",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/devices/{{deviceId}}/assign"
          }
        },
        {
          "name": "Get Device Status",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{baseUrl}}/api/v1/devices/{{deviceId}}/status"
          }
        },
        {
          "name": "List Devices",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/v1/devices?page=0&size=20",
              "query": [
                {"key": "page", "value": "0"},
                {"key": "size", "value": "20"},
                {"key": "status", "value": "ACTIVE", "disabled": true}
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Record Payment (Mobile Money)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"assignmentId\": \"{{assignmentId}}\",\n  \"amount\": 500.00,\n  \"paymentMethod\": \"MOBILE_MONEY\",\n  \"mobileNumber\": \"+254712345678\",\n  \"transactionReference\": \"TXN-2024-001\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/payments"
          }
        },
        {
          "name": "Record Payment (Cash)",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerId\": \"{{customerId}}\",\n  \"assignmentId\": \"{{assignmentId}}\",\n  \"amount\": 1000.00,\n  \"paymentMethod\": \"CASH\"\n}"
            },
            "url": "{{baseUrl}}/api/v1/payments"
          }
        },
        {
          "name": "Get Payment History (Customer)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments/{{customerId}}?page=0&size=20",
              "query": [
                {"key": "page", "value": "0"},
                {"key": "size", "value": "20"}
              ]
            }
          }
        },
        {
          "name": "Get Payments by Assignment",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{baseUrl}}/api/v1/payments/assignment/{{assignmentId}}"
          }
        }
      ]
    }
  ]
}
